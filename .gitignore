# Local .terraform directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Ignore tfvars containing secrets
*.tfvars
*.tfvars.json

# Exception: keep example tfvars
!*.example.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI configuration
.terraformrc
terraform.rc

# Terraform plan files
*.tfplan
*.plan

# Sensitive variable files
terraform.tfvars
terraform.tfvars.json

# VS Code
.vscode/

# macOS
.DS_Store

# Windows
Thumbs.db

# Logs
*.log

# Environment files
.env
.env.*

# Optional: direnv
.envrc